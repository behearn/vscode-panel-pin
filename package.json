{
  "name": "vscode-panel-pin",
  "displayName": "Panel Pin",
  "description": "Resizes the bottom panel height (Problems, Output, Debug Console, Terminal etc) to its smallest size without toggling its visibility. Toggle the pin on the status bar to switch modes. Pin to keep full height, or unpin to enable. ",
  "version": "0.0.5",
  "publisher": "brianhearn",
  "author": {
    "name": "Brian Hearn"
  },
  "license": "MIT",
  "homepage": "https://github.com/behearn/vscode-panel-pin#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/behearn/vscode-panel-pin.git"
  },
  "bugs": {
    "url": "https://github.com/behearn/vscode-panel-pin/issues"
  },
  "qna": "marketplace",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Other"
  ],
  "keywords": [
    "panel",
    "pin",
    "resize",
    "height",
    "productivity",
    "workspace",
    "ui",
    "auto-resize",
    "focus",
    "bottom-panel",
    "smart-resize",
    "editor-space",
    "panel-management",
    "height-control"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "panelPin.togglePin",
        "title": "Toggle Panel Pin State",
        "icon": "$(pin)",
        "category": "Panel Pin"
      },
      {
        "command": "panelPin.togglePinPinned",
        "title": "Unpin Panel",
        "icon": "$(pinned)",
        "category": "Panel Pin"
      },
      {
        "command": "panelPin.togglePinUnpinned",
        "title": "Pin Panel",
        "icon": "$(pin)",
        "category": "Panel Pin"
      },
      {
        "command": "panelPin.showDiagnostics",
        "title": "Show Panel Pin Diagnostics",
        "category": "Panel Pin"
      },
      {
        "command": "panelPin.reset",
        "title": "Reset Panel Pin to Default State",
        "category": "Panel Pin"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "panelPin.togglePinPinned",
          "when": "config.panelPin.showPanelTitlePinButton && panelPin.isPinned && view in panelPin.titleBarViews",
          "group": "navigation@99"
        },
        {
          "command": "panelPin.togglePinUnpinned",
          "when": "config.panelPin.showPanelTitlePinButton && !panelPin.isPinned && view in panelPin.titleBarViews",
          "group": "navigation@99"
        }
      ]
    },
    "configuration": {
      "title": "Panel Pin",
      "properties": {
        "panelPin.showStatusBarPinButton": {
          "type": "boolean",
          "default": true,
          "scope": "application",
          "description": "Show the Panel Pin button in the status bar. Disable to use only the panel title button."
        },
        "panelPin.showPanelTitlePinButton": {
          "type": "boolean",
          "default": true,
          "scope": "application",
          "description": "Show the Panel Pin button in supported panel view title bars (Problems, Output, Debug Console, Terminal). Disable to use only the status bar button."
        },
        "panelPin.titleBarViewIds": {
          "type": "array",
          "default": [
            "workbench.panel.markers.view",
            "workbench.panel.output",
            "workbench.panel.repl.view",
            "~remote.forwardedPorts",
            "terminal"
          ],
          "scope": "application",
          "items": {
            "type": "string"
          },
          "description": "View ids that should show the Panel Pin title-bar button. Add other VS Code view ids here if you want the button in additional panels."
        },
        "panelPin.resizeStepCount": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "maximum": 20,
          "scope": "application",
          "description": "How many height adjustment steps Panel Pin uses when expanding the bottom panel after pinning. Set to 0 to disable automatic expansion and control the height manually. Unpinning always collapses the panel as far down as possible without hiding it."
        }
      }
    },
    "keybindings": [      
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "compile:watch": "tsc -watch -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",    
    "clean": "rimraf out",
    "build": "node scripts/build.js",
    "package": "vsce package --out vscode-panel-pin.vsix",
    "package:pre-release": "vsce package --pre-release --out vscode-panel-pin-pre.vsix",
    "publish": "vsce publish",
    "publish:pre-release": "vsce publish --pre-release",
    "install-local": "code --install-extension vscode-panel-pin.vsix",
    "verify-package": "vsce ls"
  },
  "devDependencies": {
    "@types/glob": "^8.0.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/sinon": "^17.0.4",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vscode/test-electron": "^2.2.0",
    "@vscode/vsce": "^3.9.2",
    "audit-ci": "^6.6.1",
    "eslint": "^10.7.0",
    "rimraf": "^5.0.0",
    "typescript": "^4.9.4"
  }
}
